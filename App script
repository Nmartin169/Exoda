/**
 * Creates a custom menu when the spreadsheet opens.
 */
function onOpen() {
  const ui = SpreadsheetApp.getUi();
  ui.createMenu('🏥 EHR System')
      .addItem('Refresh Pharmacy (Clear & Sync)', 'INITIAL_SYNC_ALL_DATA')
      .addToUi();
}

/**
 * FULL SYNC: Wipes Pharmacy and appends all Encounter data in order.
 */
function INITIAL_SYNC_ALL_DATA() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const encounterRange = ss.getRangeByName("ENCOUNTER_RANGE");
  const pharmacyRange = ss.getRangeByName("PHARMACY_RANGE");
  
  if (!encounterRange || !pharmacyRange) {
    SpreadsheetApp.getUi().alert("Error: Ensure both ENCOUNTER_RANGE and PHARMACY_RANGE are defined.");
    return;
  }

  const encounterSheet = encounterRange.getSheet();
  const encounterData = encounterRange.getValues();
  const encounterHeaders = encounterData[0].map(h => h.toString().trim().toUpperCase());
  
  const pSheet = pharmacyRange.getSheet();
  const pStartRow = pharmacyRange.getRow();
  const pStartCol = pharmacyRange.getColumn();
  const pWidth = pharmacyRange.getWidth();

  // 1. Clear existing data in Pharmacy range (everything below the header)
  if (pharmacyRange.getHeight() > 1) {
    pSheet.getRange(pStartRow + 1, pStartCol, pharmacyRange.getHeight() - 1, pWidth).clearContent();
  }

  // 2. Loop through Encounter data and append valid rows
  let syncCount = 0;
  for (let i = 1; i < encounterData.length; i++) {
    const encId = encounterData[i][encounterHeaders.indexOf("ENCOUNTER_ID")];
    const medication = encounterData[i][encounterHeaders.indexOf("MEDICATION")];
    
    // Only sync if there is an ID and a Medication (skips empty rows)
    if (encId && medication) {
      const rowNum = encounterRange.getRow() + i;
      const startCol = encounterRange.getColumn();
      // We use the standard sync function which now handles the "Append" logic
      syncToPharmacy(encounterSheet, rowNum, startCol, encounterHeaders);
      syncCount++;
    }
  }
  SpreadsheetApp.getUi().alert('Success: Pharmacy cleared and ' + syncCount + ' orders appended in order.');
}

/**
 * Standard Sync: Finds existing row by ID to update, or appends to bottom if new.
 */
function syncToPharmacy(encounterSheet, rowNum, startCol, encounterHeaders) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const pharmacyRange = ss.getRangeByName("PHARMACY_RANGE");
  if (!pharmacyRange) return;

  const pharmacySheet = pharmacyRange.getSheet();
  const pStartRow = pharmacyRange.getRow();
  const pStartCol = pharmacyRange.getColumn();
  const pWidth = pharmacyRange.getWidth();

  const pharmacyHeaders = pharmacySheet.getRange(pStartRow, pStartCol, 1, pWidth).getValues()[0]
                                       .map(h => h.toString().trim().toUpperCase());
  
  const colsToMirror = [
    "PATIENT_ID", "DATE_OF_VISIT", "TIME_OF_VISIT", "ENCOUNTER_ID", 
    "MEDICATION", "STRENGTH_MG_ML", "ROUTE", "DOSAGE", "FREQUENCY", "PHYSICIAN"
  ];

  const encIdIdxEncounter = encounterHeaders.indexOf("ENCOUNTER_ID");
  const encounterId = encounterSheet.getRange(rowNum, startCol + encIdIdxEncounter).getValue();

  if (!encounterId) return;

  // Search for existing ID in Pharmacy to see if we update or append
  const pEncIdIdx = pharmacyHeaders.indexOf("ENCOUNTER_ID");
  const pharmacyData = pharmacyRange.getValues();
  let targetRow = -1;
  
  if (pEncIdIdx !== -1) {
    for (let i = 1; i < pharmacyData.length; i++) {
      if (pharmacyData[i][pEncIdIdx] === encounterId) {
        targetRow = pStartRow + i; 
        break;
      }
    }
  }

  // If ID not found, find the next available empty row at the bottom of the table
  const writeRow = (targetRow !== -1) ? targetRow : getFirstEmptyRowInRange(pharmacyRange);

  colsToMirror.forEach(colName => {
    const srcIdx = encounterHeaders.indexOf(colName);
    const destIdx = pharmacyHeaders.indexOf(colName);

    if (srcIdx !== -1 && destIdx !== -1) {
      const value = encounterSheet.getRange(rowNum, startCol + srcIdx).getValue();
      pharmacySheet.getRange(writeRow, pStartCol + destIdx).setValue(value);
    }
  });
}

/**
 * Helper: Finds the first empty row specifically within the PHARMACY_RANGE
 */
function getFirstEmptyRowInRange(range) {
  const values = range.getValues();
  for (let i = 0; i < values.length; i++) {
    if (values[i].join("") === "") {
      return range.getRow() + i;
    }
  }
  return range.getLastRow() + 1; // If range is full, go one below
}

