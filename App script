/**
 * Creates a custom menu when the spreadsheet opens.
 */
function onOpen() {
  const ui = SpreadsheetApp.getUi();
  ui.createMenu('🏥 EHR System')
      .addItem('Refresh Pharmacy (Maintain Status)', 'INITIAL_SYNC_ALL_DATA')
      .addToUi();
}

/**
 * Main Entry Point: Google Sheets Trigger
 */
function onEdit(e) {
  const context = getEventContext(e);
  if (!context) return;

  // 1. Handle Automatic Timestamping (All Sheets)
  handleTimestamping(context);

  // 2. Handle Data Swapping (Encounter Sheet)
  handleDataSwaps(context);

  // 3. Handle Clinical Logic (Encounter ID & Pharmacy Sync)
  if (context.activeRangeName === "ENCOUNTER_RANGE") {
    handleEncounterLogic(context);
  }
}

/**
 * Extracts and validates metadata from the edit event
 */
function getEventContext(e) {
  const range = e.range;
  if (!e.value || range.getNumRows() > 1) return null;

  const sheet = range.getSheet();
  const source = e.source;
  
  // ADDED PHARMACY_RANGE here to allow it to be processed
  const timestampRanges = ["LOG_PROVIDER_RANGE", "VISIT_RANGE", "ENCOUNTER_RANGE", "PHARMACY_RANGE"];
  const clinicalRanges = ["ENCOUNTER_RANGE"];
  const allNames = [...new Set([...timestampRanges, ...clinicalRanges])];

  let activeRangeName = "";
  let activeRangeObject = null;

  for (let name of allNames) {
    let nr = source.getRangeByName(name);
    if (nr && isCellInNamedRange(range, nr)) {
      activeRangeName = name;
      activeRangeObject = nr;
      break;
    }
  }

  if (!activeRangeObject) return null;

  const startRow = activeRangeObject.getRow();
  const startCol = activeRangeObject.getColumn();
  const headers = sheet.getRange(startRow, startCol, 1, activeRangeObject.getWidth()).getValues()[0]
                       .map(h => h.toString().trim().toUpperCase());
  
  const colIndex = range.getColumn() - startCol;
  const columnName = headers[colIndex] || "";

  return {
    e, range, sheet, source,
    activeRangeName, activeRangeObject,
    columnName, headers, startCol,
    isTimeZone: timestampRanges.includes(activeRangeName)
  };
}

/**
 * Logic for updating timestamps (Offsets 1 to the right)
 */
function handleTimestamping(ctx) {
  if (!ctx.isTimeZone) return;

  // Added DISPENSED_DATE to the condition
  const triggers = ["DATE_OF_VISIT", "DATE_OF_DEPARTURE", "DISPENSED_DATE"];
  
  if (triggers.includes(ctx.columnName)) {
    const targetCell = ctx.range.offset(0, 1);
    ctx.e.value === ""
      ? targetCell.clearContent()
      : targetCell.setValue(new Date()).setNumberFormat("HH:mm:ss");
  }
}

/**
 * Logic specific to Encounter sheet (ID generation and Pharmacy Sync)
 */
function handleEncounterLogic(ctx) {
  // Generate ID if necessary
  pollAndGenerateEncounterId(ctx.sheet, ctx.activeRangeObject, ctx.range.getRow(), ctx.startCol, ctx.headers);

  // Sync to Pharmacy if relevant columns edited
  const pharmacyTriggers = ["PATIENT_ID", "ENCOUNTER_ID", "MEDICATION", "STRENGTH_MG_ML", "ROUTE", "DOSAGE", "FREQUENCY", "PHYSICIAN"];
  if (pharmacyTriggers.includes(ctx.columnName)) {
    syncToPharmacy(ctx.sheet, ctx.range.getRow(), ctx.startCol, ctx.headers);
  }
}

/**
 * Logic for swapping Names for IDs/Codes
 */
function handleDataSwaps(ctx) {
  if (ctx.activeRangeName !== "ENCOUNTER_RANGE") return;

  const mapping = {
    "PATIENT_ID": { lookupRangeName: "VISIT_RANGE", searchHeader: "PATIENT_NAME", returnHeader: "PATIENT_ID", isPatientSwap: true }
  };
  
  const config = mapping[ctx.columnName];
  if (!config) return;

  const lookupRange = ctx.source.getRangeByName(config.lookupRangeName);
  if (!lookupRange) return;

  const lookupData = lookupRange.getValues();
  const lHeaders = lookupData[0].map(h => h.toString().trim().toUpperCase());

  const searchIdx = lHeaders.indexOf(config.searchHeader);
  const returnIdx = lHeaders.indexOf(config.returnHeader);
  if (searchIdx === -1 || returnIdx === -1) return;

  let matchRow = lookupData.find(row => row[searchIdx] == ctx.e.value);
  if (!matchRow) return;

  const matchValue = matchRow[returnIdx];
  const rule = ctx.range.getDataValidation();
  ctx.range.setDataValidation(null);
  ctx.range.setValue(matchValue);

  if (config.isPatientSwap) {
    const dobIdx = lHeaders.indexOf("DATE_OF_BIRTH");
    const ageColIdx = ctx.headers.indexOf("AGE");
    if (ageColIdx !== -1 && matchRow[dobIdx] instanceof Date) {
      ctx.sheet.getRange(ctx.range.getRow(), ctx.startCol + ageColIdx).setValue(calculateAge(matchRow[dobIdx]));
    }
  }

  SpreadsheetApp.flush();
  ctx.range.setDataValidation(rule);
}

/**
 * Pharmacy Sync (Preserves manual Pharmacist entries)
 */
function syncToPharmacy(encounterSheet, rowNum, startCol, encounterHeaders) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const pharmacyRange = ss.getRangeByName("PHARMACY_RANGE");
  if (!pharmacyRange) return;

  const pSheet = pharmacyRange.getSheet();
  const pHeaders = pSheet.getRange(pharmacyRange.getRow(), pharmacyRange.getColumn(), 1, pharmacyRange.getWidth()).getValues()[0].map(h => h.toString().trim().toUpperCase());
  
  const doctorCols = ["PATIENT_ID", "DATE_OF_VISIT", "TIME_OF_VISIT", "ENCOUNTER_ID", "MEDICATION", "STRENGTH_MG_ML", "ROUTE", "DOSAGE", "FREQUENCY", "PHYSICIAN"];
  const encId = encounterSheet.getRange(rowNum, startCol + encounterHeaders.indexOf("ENCOUNTER_ID")).getValue();
  if (!encId) return;

  const pData = pharmacyRange.getValues();
  const pEncIdIdx = pHeaders.indexOf("ENCOUNTER_ID");
  let targetRow = -1;

  for (let i = 1; i < pData.length; i++) {
    if (pData[i][pEncIdIdx] === encId) {
      targetRow = pharmacyRange.getRow() + i;
      break;
    }
  }

  const writeRow = (targetRow !== -1) ? targetRow : getFirstEmptyRowInRange(pharmacyRange);
  
  if (targetRow === -1 && pHeaders.indexOf("STATUS") !== -1) {
    pSheet.getRange(writeRow, pharmacyRange.getColumn() + pHeaders.indexOf("STATUS")).setValue("Pending");
  }

  doctorCols.forEach(col => {
    const sIdx = encounterHeaders.indexOf(col);
    const dIdx = pHeaders.indexOf(col);
    if (sIdx !== -1 && dIdx !== -1) {
      pSheet.getRange(writeRow, pharmacyRange.getColumn() + dIdx).setValue(encounterSheet.getRange(rowNum, startCol + sIdx).getValue());
    }
  });
}

/**
 * Full Refresh Tool
 */
function INITIAL_SYNC_ALL_DATA() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const encRange = ss.getRangeByName("ENCOUNTER_RANGE");
  if (!encRange) return;

  const data = encRange.getValues();
  const headers = data[0].map(h => h.toString().trim().toUpperCase());
  
  for (let i = 1; i < data.length; i++) {
    if (data[i][headers.indexOf("ENCOUNTER_ID")]) {
      syncToPharmacy(encRange.getSheet(), encRange.getRow() + i, encRange.getColumn(), headers);
    }
  }
  SpreadsheetApp.getUi().alert('Sync Complete.');
}

// --- HELPERS ---

function calculateAge(dob) {
  const today = new Date();
  let age = today.getFullYear() - dob.getFullYear();
  if (today.getMonth() < dob.getMonth() || (today.getMonth() == dob.getMonth() && today.getDate() < dob.getDate())) age--;
  return age;
}

function isCellInNamedRange(cell, nr) {
  if (cell.getSheet().getName() !== nr.getSheet().getName()) return false;
  const r = cell.getRow(), c = cell.getColumn();
  // Ensure we are inside the range but NOT in the header row
  return (r > nr.getRow() && r <= nr.getLastRow() && c >= nr.getColumn() && c <= nr.getLastColumn());
}

function getFirstEmptyRowInRange(range) {
  const values = range.getValues();
  for (let i = 0; i < values.length; i++) {
    if (values[i].join("").trim() === "") return range.getRow() + i;
  }
  return range.getLastRow() + 1;
}

function pollAndGenerateEncounterId(sheet, encRange, rowNum, startCol, headers) {
  const pIdx = headers.indexOf("PATIENT_ID"), dIdx = headers.indexOf("DATE_OF_VISIT"), eIdx = headers.indexOf("ENCOUNTER_ID");
  if (pIdx === -1 || dIdx === -1 || eIdx === -1) return;
  
  let pId = sheet.getRange(rowNum, startCol + pIdx).getValue();
  let dVal = sheet.getRange(rowNum, startCol + dIdx).getValue();
  if (pId && dVal && !sheet.getRange(rowNum, startCol + eIdx).getValue()) {
    let dateStr = Utilities.formatDate(new Date(dVal), Session.getScriptTimeZone(), "yyyyMMdd");
    let count = encRange.getValues().slice(0, rowNum - encRange.getRow() + 1).filter(r => r[pIdx] == pId).length;
    sheet.getRange(rowNum, startCol + eIdx).setValue(`${dateStr}-${pId}-${count.toString().padStart(2, '0')}`);
  }
}
