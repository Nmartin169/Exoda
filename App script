/**
 * Creates a custom menu when the spreadsheet opens.
 */
function onOpen() {
  const ui = SpreadsheetApp.getUi();
  ui.createMenu('🏥 EHR System')
      .addItem('Refresh Pharmacy (Maintain Status)', 'INITIAL_SYNC_ALL_DATA')
      .addToUi();
}

/**
 * Main Entry Point: Google Sheets Trigger
 * Logic preserved from your shared script
 */
function onEdit(e) {
  const range = e.range;
  const sheet = range.getSheet();
  const source = e.source;
  const val = e.value;

  if (!val || range.getNumRows() > 1) return;

  const encounterRange = source.getRangeByName("ENCOUNTER_RANGE");
  const pharmacyRange = source.getRangeByName("PHARMACY_RANGE");

  // 1. Check if the edit is in the ENCOUNTER table
  if (encounterRange && isCellInNamedRange(range, encounterRange)) {
    const startRow = encounterRange.getRow();
    const startCol = encounterRange.getColumn();
    const headers = sheet.getRange(startRow, startCol, 1, encounterRange.getWidth()).getValues()[0]
                         .map(h => h.toString().trim().toUpperCase());
    
    const colIndex = range.getColumn() - startCol;
    const columnName = headers[colIndex] || "";
    const rowNum = range.getRow();

    // HANDLE PATIENT_ID SWAP (Logic Preserved)
    if (columnName === "PATIENT_ID") {
      handlePatientIdSwap(e, headers, rowNum, startCol);
    }

    // HANDLE TIMESTAMPING (Logic Preserved)
    if (columnName === "DATE_OF_VISIT") {
      const timeColIdx = headers.indexOf("TIME_OF_VISIT");
      if (timeColIdx !== -1) {
        sheet.getRange(rowNum, startCol + timeColIdx).setValue(new Date());
      }
    }

    // ENCOUNTER_ID GENERATION (Your Full Logic with 5-attempt re-checks)
    pollAndGenerateEncounterId(sheet, encounterRange, rowNum, startCol, headers);

    // PHARMACY SYNC TRIGGER
    const pharmacyTriggers = ["PATIENT_ID", "ENCOUNTER_ID", "MEDICATION", "STRENGTH_MG_ML", "ROUTE", "DOSAGE", "FREQUENCY", "PHYSICIAN"];
    if (pharmacyTriggers.includes(columnName)) {
      syncToPharmacy(sheet, rowNum, startCol, headers);
    }
    return; // Exit if encounter logic was handled
  }

  // 2. Handle Simple Timestamps for all other ranges (LOG_PROVIDER, VISIT, PHARMACY)
  handleSimpleTimestamp(e);
}

/**
 * ENCOUNTER_ID GENERATION: PRESERVED FULL LOGIC
 * Includes the 5-attempt loop, 1000ms delay, and SpreadsheetApp.flush()
 */
function pollAndGenerateEncounterId(sheet, encounterRange, rowNum, startCol, headers) {
  const pIdColIdx = headers.indexOf("PATIENT_ID");
  const dVisColIdx = headers.indexOf("DATE_OF_VISIT");
  const encIdColIdx = headers.indexOf("ENCOUNTER_ID");

  if (pIdColIdx === -1 || dVisColIdx === -1 || encIdColIdx === -1) return;

  for (let attempt = 0; attempt < 5; attempt++) {
    SpreadsheetApp.flush(); 
    
    let patientId = sheet.getRange(rowNum, startCol + pIdColIdx).getValue();
    let dateVal = sheet.getRange(rowNum, startCol + dVisColIdx).getValue();
    let existingEncId = sheet.getRange(rowNum, startCol + encIdColIdx).getValue();

    if (existingEncId) break;

    if (patientId && dateVal && patientId !== "" && dateVal !== "") {
      let dateStr = (dateVal instanceof Date) 
        ? Utilities.formatDate(dateVal, Session.getScriptTimeZone(), "yyyyMMdd")
        : dateVal.toString().replace(/[^0-9]/g, "").substring(0, 8);

      if (dateStr.length === 8) {
        const allData = encounterRange.getValues();
        const relativeRow = rowNum - encounterRange.getRow();
        
        let count = 0;
        for (let i = 0; i <= relativeRow; i++) {
          if (allData[i][pIdColIdx].toString() == patientId.toString()) {
            count++;
          }
        }
        
        const sequence = count.toString().padStart(2, '0');
        const finalId = `${dateStr}-${patientId}-${sequence}`;
        sheet.getRange(rowNum, startCol + encIdColIdx).setValue(finalId);
        break; 
      }
    }
    Utilities.sleep(1000);
  }
}

/**
 * PATIENT ID SWAP: PRESERVED FULL LOGIC
 */
function handlePatientIdSwap(e, headers, rowNum, startCol) {
  const source = e.source;
  const visitRange = source.getRangeByName("VISIT_RANGE");
  if (!visitRange) return;

  const vData = visitRange.getValues();
  const vHeaders = vData[0].map(h => h.toString().trim().toUpperCase());
  const nameIdx = vHeaders.indexOf("PATIENT_NAME");
  const idIdx = vHeaders.indexOf("PATIENT_ID");
  const dobIdx = vHeaders.indexOf("DATE_OF_BIRTH");

  const match = vData.find(r => r[nameIdx].toString().trim() == e.value.toString().trim());
  if (match) {
    const pId = match[idIdx];
    const rule = e.range.getDataValidation();
    e.range.setDataValidation(null);
    e.range.setValue(pId);
    
    const ageColIdx = headers.indexOf("AGE");
    if (ageColIdx !== -1 && match[dobIdx] instanceof Date) {
      e.range.getSheet().getRange(rowNum, startCol + ageColIdx).setValue(calculateAge(match[dobIdx]));
    }

    const vIdColIdx = headers.indexOf("VISIT_ID");
    if (vIdColIdx !== -1) {
      e.range.getSheet().getRange(rowNum, startCol + vIdColIdx).setValue(getRecentVisit(vData, vHeaders, pId));
    }

    SpreadsheetApp.flush();
    if (rule) e.range.setDataValidation(rule);
  }
}

/**
 * TIMESTAMP LOGIC: EXTENDED TO INCLUDE DISPENSED_DATE
 */
function handleSimpleTimestamp(e) {
  const sheet = e.range.getSheet();
  const row = e.range.getRow();
  
  // Scans Row 1 for headers across any tab
  const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0]
                       .map(h => h.toString().trim().toUpperCase());
  const colIndex = e.range.getColumn() - 1;
  const colName = headers[colIndex] || "";
  
  const triggers = ["DATE_OF_VISIT", "DATE_OF_DEPARTURE", "DISPENSED_DATE"];
  
  if (triggers.includes(colName)) {
    e.range.offset(0, 1).setValue(new Date()).setNumberFormat("HH:mm:ss");
  }
}

/**
 * PHARMACY SYNC: UPDATED TO PRESERVE PHARMACIST DATA
 */
function syncToPharmacy(encounterSheet, rowNum, startCol, encounterHeaders) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const pharmacyRange = ss.getRangeByName("PHARMACY_RANGE");
  if (!pharmacyRange) return;

  const pSheet = pharmacyRange.getSheet();
  const pHeaders = pSheet.getRange(pharmacyRange.getRow(), pharmacyRange.getColumn(), 1, pharmacyRange.getWidth()).getValues()[0].map(h => h.toString().trim().toUpperCase());
  
  const doctorCols = ["PATIENT_ID", "DATE_OF_VISIT", "TIME_OF_VISIT", "ENCOUNTER_ID", "MEDICATION", "STRENGTH_MG_ML", "ROUTE", "DOSAGE", "FREQUENCY", "PHYSICIAN"];
  const encId = encounterSheet.getRange(rowNum, startCol + encounterHeaders.indexOf("ENCOUNTER_ID")).getValue();
  if (!encId) return;

  const pData = pharmacyRange.getValues();
  const pEncIdIdx = pHeaders.indexOf("ENCOUNTER_ID");
  let targetRow = -1;

  for (let i = 1; i < pData.length; i++) {
    if (pData[i][pEncIdIdx] === encId) {
      targetRow = pharmacyRange.getRow() + i;
      break;
    }
  }

  const writeRow = (targetRow !== -1) ? targetRow : getFirstEmptyRowInRange(pharmacyRange);
  
  if (targetRow === -1 && pHeaders.indexOf("STATUS") !== -1) {
    pSheet.getRange(writeRow, pharmacyRange.getColumn() + pHeaders.indexOf("STATUS")).setValue("Pending");
  }

  doctorCols.forEach(col => {
    const sIdx = encounterHeaders.indexOf(col);
    const dIdx = pHeaders.indexOf(col);
    if (sIdx !== -1 && dIdx !== -1) {
      pSheet.getRange(writeRow, pharmacyRange.getColumn() + dIdx).setValue(encounterSheet.getRange(rowNum, startCol + sIdx).getValue());
    }
  });
}

function INITIAL_SYNC_ALL_DATA() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const encRange = ss.getRangeByName("ENCOUNTER_RANGE");
  if (!encRange) return;
  const data = encRange.getValues();
  const headers = data[0].map(h => h.toString().trim().toUpperCase());
  for (let i = 1; i < data.length; i++) {
    if (data[i][headers.indexOf("ENCOUNTER_ID")]) {
      syncToPharmacy(encRange.getSheet(), encRange.getRow() + i, encRange.getColumn(), headers);
    }
  }
  SpreadsheetApp.getUi().alert('Sync Complete.');
}

// --- REMAINING HELPERS (PRESERVED) ---

function getRecentVisit(data, headers, pId) {
  const pIdx = headers.indexOf("PATIENT_ID");
  const vIdx = headers.indexOf("VISIT_ID");
  const matches = data.filter(r => r[pIdx].toString() == pId.toString() && r[vIdx]).map(r => r[vIdx].toString()).sort().reverse();
  return matches.length > 0 ? matches[0] : "";
}

function calculateAge(dob) {
  const today = new Date();
  let age = today.getFullYear() - dob.getFullYear();
  const m = today.getMonth() - dob.getMonth();
  if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) age--;
  return age;
}

function isCellInNamedRange(cell, nr) {
  const sheetName = cell.getSheet().getName();
  const nrSheetName = nr.getSheet().getName();
  if (sheetName !== nrSheetName) return false;
  const r = cell.getRow();
  const c = cell.getColumn();
  return (r >= nr.getRow() && r <= nr.getLastRow() && c >= nr.getColumn() && c <= nr.getLastColumn());
}

function getFirstEmptyRowInRange(range) {
  const values = range.getValues();
  for (let i = 0; i < values.length; i++) {
    if (values[i].join("").trim() === "") return range.getRow() + i;
  }
  return range.getLastRow() + 1;
}
