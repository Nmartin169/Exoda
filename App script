/**
 * Creates a custom menu when the spreadsheet opens.
 */
function onOpen() {
  const ui = SpreadsheetApp.getUi();
  ui.createMenu('🏥 EHR System')
      .addItem('Refresh Pharmacy (Maintain Status)', 'INITIAL_SYNC_ALL_DATA')
      .addItem('Sync Provider Registry (Bulk)', 'SYNC_PROVIDER_REGISTRY_BULK')
      .addToUi();
}

/**
 * Main Entry Point: Google Sheets Trigger
 * Optimized for bulk pastes (Google Forms / Manual Copy-Paste)
 */
function onEdit(e) {
  if (!e) return;
  const range = e.range;
  const source = e.source;
  
  // 1. Identify if the edit happened within a known Named Range
  const timestampRanges = ["LOG_PROVIDER_RANGE", "VISIT_RANGE", "ENCOUNTER_RANGE", "PHARMACY_RANGE", "PROVIDER_ENTRY_RANGE"];
  let activeRangeName = "";
  let activeRangeObject = null;

  for (let name of timestampRanges) {
    let nr = source.getRangeByName(name);
    if (nr && isCellInNamedRange(range, nr)) {
      activeRangeName = name;
      activeRangeObject = nr;
      break;
    }
  }

  if (!activeRangeObject) return;

  // 2. Loop through every row in the edited range (Handles Bulk Pastes)
  const startRow = range.getRow();
  const numRows = range.getNumRows();

  for (let i = 0; i < numRows; i++) {
    const currentRowNum = startRow + i;
    // Create a specific context for this single row within the edit
    const rowRange = range.getSheet().getRange(currentRowNum, range.getColumn(), 1, range.getWidth());
    const context = getEventContextForRow(e, rowRange, activeRangeName, activeRangeObject);
    
    if (!context) continue;

    // A. Handle Automatic Timestamping
    handleTimestamping(context);

    // B. Handle Encounter-Specific Logic
    if (context.activeRangeName === "ENCOUNTER_RANGE") {
      handleEncounterLogic(context);
    }

    // C. Handle Provider Entry Sync
    if (context.activeRangeName === "PROVIDER_ENTRY_RANGE") {
      handleProviderSync(context);
    }
  }
}

/**
 * Context Parser: Adapted to handle specific rows during bulk edits
 */
function getEventContextForRow(e, rowRange, activeRangeName, activeRangeObject) {
  const sheet = rowRange.getSheet();
  const startRow = activeRangeObject.getRow();
  const startCol = activeRangeObject.getColumn();
  
  const headers = sheet.getRange(startRow, startCol, 1, activeRangeObject.getWidth()).getValues()[0]
                       .map(h => h.toString().trim().toUpperCase());
  
  const colIndex = rowRange.getColumn() - startCol;
  const columnName = headers[colIndex] || "";

  return {
    e, 
    range: rowRange, 
    sheet, 
    source: e.source,
    activeRangeName, 
    activeRangeObject,
    columnName, 
    headers, 
    startCol,
    isTimestampZone: true // Only gets here if it's in a timestamp-enabled range
  };
}

/**
 * Provider Sync: Maps Entry Table to Registry Table
 */
function handleProviderSync(ctx) {
  const ss = ctx.source;
  const targetRange = ss.getRangeByName("PROVIDER_RANGE");
  if (!targetRange) return;

  const targetSheet = targetRange.getSheet();
  const tStartRow = targetRange.getRow();
  const tStartCol = targetRange.getColumn();
  const targetHeaders = targetSheet.getRange(tStartRow, tStartCol, 1, targetRange.getWidth()).getValues()[0]
                                   .map(h => h.toString().trim().toUpperCase());

  const mapping = {
    "PROVIDER NAME": "PROVIDER_NAME",
    "DATE OF BIRTH": "DATE_OF_BIRTH",
    "GENDER": "GENDER",
    "DESIGNATION": "DESIGNATION"
  };

  const rowNum = ctx.range.getRow();
  const nameIdx = ctx.headers.indexOf("PROVIDER NAME");
  if (nameIdx === -1) return;

  const providerName = ctx.sheet.getRange(rowNum, ctx.startCol + nameIdx).getValue();
  if (!providerName) return;

  // Check for existing entry to update or find new row
  const targetData = targetRange.getValues();
  const targetNameIdx = targetHeaders.indexOf("PROVIDER_NAME");
  let targetRow = -1;

  for (let i = 1; i < targetData.length; i++) {
    if (targetData[i][targetNameIdx].toString().toLowerCase() === providerName.toString().toLowerCase()) {
      targetRow = tStartRow + i;
      break;
    }
  }

  const writeRow = (targetRow !== -1) ? targetRow : getFirstEmptyRowInRange(targetRange);

  for (let entryHead in mapping) {
    const srcIdx = ctx.headers.indexOf(entryHead);
    const destIdx = targetHeaders.indexOf(mapping[entryHead]);
    if (srcIdx !== -1 && destIdx !== -1) {
      const val = ctx.sheet.getRange(rowNum, ctx.startCol + srcIdx).getValue();
      targetSheet.getRange(writeRow, tStartCol + destIdx).setValue(val);
    }
  }
}

/**
 * Encounter Logic
 */
function handleEncounterLogic(ctx) {
  const rowNum = ctx.range.getRow();
  if (ctx.columnName === "PATIENT_ID") {
    handlePatientIdSwap(ctx.e, ctx.headers, rowNum, ctx.startCol);
  }
  pollAndGenerateEncounterId(ctx.sheet, ctx.activeRangeObject, rowNum, ctx.startCol, ctx.headers);
  
  const pharmacyTriggers = ["PATIENT_ID", "ENCOUNTER_ID", "MEDICATION", "STRENGTH_MG_ML", "ROUTE", "DOSAGE", "FREQUENCY", "PHYSICIAN"];
  if (pharmacyTriggers.includes(ctx.columnName)) {
    syncToPharmacy(ctx.sheet, rowNum, ctx.startCol, ctx.headers);
  }
}

/**
 * Timestamping Logic
 */
function handleTimestamping(ctx) {
  const triggers = ["DATE_OF_VISIT", "DATE_OF_DEPARTURE", "DISPENSED_DATE"];
  if (triggers.includes(ctx.columnName)) {
    const targetCell = ctx.range.offset(0, 1);
    if (ctx.range.getValue() === "") {
      targetCell.clearContent();
    } else {
      targetCell.setValue(new Date());
    }
  }
}

/**
 * Pharmacy Sync
 */
function syncToPharmacy(encounterSheet, rowNum, startCol, encounterHeaders) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const pharmacyRange = ss.getRangeByName("PHARMACY_RANGE");
  if (!pharmacyRange) return;

  const pharmacySheet = pharmacyRange.getSheet();
  const pStartRow = pharmacyRange.getRow();
  const pStartCol = pharmacyRange.getColumn();
  const pharmacyHeaders = pharmacySheet.getRange(pStartRow, pStartCol, 1, pharmacyRange.getWidth()).getValues()[0]
                                       .map(h => h.toString().trim().toUpperCase());
  
  const colsToMirror = ["PATIENT_ID", "DATE_OF_VISIT", "TIME_OF_VISIT", "ENCOUNTER_ID", "MEDICATION", "STRENGTH_MG_ML", "ROUTE", "DOSAGE", "FREQUENCY", "PHYSICIAN"];
  const encounterId = encounterSheet.getRange(rowNum, startCol + encounterHeaders.indexOf("ENCOUNTER_ID")).getValue();
  if (!encounterId) return;

  const pharmacyData = pharmacyRange.getValues();
  const pEncIdIdx = pharmacyHeaders.indexOf("ENCOUNTER_ID");
  let targetRow = -1;
  
  for (let i = 1; i < pharmacyData.length; i++) {
    if (pharmacyData[i][pEncIdIdx] === encounterId) {
      targetRow = pStartRow + i;
      break;
    }
  }

  const writeRow = (targetRow !== -1) ? targetRow : getFirstEmptyRowInRange(pharmacyRange);
  colsToMirror.forEach(colName => {
    const srcIdx = encounterHeaders.indexOf(colName);
    const destIdx = pharmacyHeaders.indexOf(colName);
    if (srcIdx !== -1 && destIdx !== -1) {
      const val = encounterSheet.getRange(rowNum, startCol + srcIdx).getValue();
      pharmacySheet.getRange(writeRow, pStartCol + destIdx).setValue(val);
    }
  });
}

/**
 * Menu Function: Initial Sync Pharmacy
 */
function INITIAL_SYNC_ALL_DATA() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const encounterRange = ss.getRangeByName("ENCOUNTER_RANGE");
  if (!encounterRange) return;
  const data = encounterRange.getValues();
  const headers = data[0].map(h => h.toString().trim().toUpperCase());
  for (let i = 1; i < data.length; i++) {
    if (data[i][headers.indexOf("ENCOUNTER_ID")]) {
      syncToPharmacy(encounterRange.getSheet(), encounterRange.getRow() + i, encounterRange.getColumn(), headers);
    }
  }
  SpreadsheetApp.getUi().alert('Pharmacy Sync Complete.');
}

/**
 * Menu Function: Bulk Sync Provider Registry
 */
function SYNC_PROVIDER_REGISTRY_BULK() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const entryRange = ss.getRangeByName("PROVIDER_ENTRY_RANGE");
  if (!entryRange) return;
  const data = entryRange.getValues();
  const headers = data[0].map(h => h.toString().trim().toUpperCase());
  for (let i = 1; i < data.length; i++) {
    if (data[i][headers.indexOf("PROVIDER NAME")]) {
      handleProviderSync({
        source: ss, sheet: entryRange.getSheet(), range: entryRange.offset(i, 0, 1, 1),
        headers: headers, startCol: entryRange.getColumn()
      });
    }
  }
  SpreadsheetApp.getUi().alert('Provider Registry Sync Complete.');
}

/**
 * HELPERS & CORE LOGIC
 */
function pollAndGenerateEncounterId(sheet, encounterRange, rowNum, startCol, headers) {
  const pIdColIdx = headers.indexOf("PATIENT_ID");
  const dVisColIdx = headers.indexOf("DATE_OF_VISIT");
  const encIdColIdx = headers.indexOf("ENCOUNTER_ID");
  if (pIdColIdx === -1 || dVisColIdx === -1 || encIdColIdx === -1) return;

  for (let attempt = 0; attempt < 3; attempt++) {
    SpreadsheetApp.flush();
    let pId = sheet.getRange(rowNum, startCol + pIdColIdx).getValue();
    let dateVal = sheet.getRange(rowNum, startCol + dVisColIdx).getValue();
    if (sheet.getRange(rowNum, startCol + encIdColIdx).getValue()) break;

    if (pId && dateVal) {
      let dateStr = (dateVal instanceof Date) ? Utilities.formatDate(dateVal, Session.getScriptTimeZone(), "yyyyMMdd") : dateVal.toString().replace(/[^0-9]/g, "").substring(0, 8);
      const allData = encounterRange.getValues();
      let count = 0;
      for (let i = 0; i <= (rowNum - encounterRange.getRow()); i++) {
        if (allData[i][pIdColIdx].toString() == pId.toString()) count++;
      }
      const finalId = `${dateStr}-${pId}-${count.toString().padStart(2, '0')}`;
      sheet.getRange(rowNum, startCol + encIdColIdx).setValue(finalId);
      syncToPharmacy(sheet, rowNum, startCol, headers);
      break;
    }
    Utilities.sleep(500);
  }
}

function handlePatientIdSwap(e, headers, rowNum, startCol) {
  const visitRange = e.source.getRangeByName("VISIT_RANGE");
  if (!visitRange) return;
  const vData = visitRange.getValues();
  const vHeaders = vData[0].map(h => h.toString().trim().toUpperCase());
  const match = vData.find(r => r[vHeaders.indexOf("PATIENT_NAME")].toString().trim() == e.value.toString().trim());
  if (match) {
    const pId = match[vHeaders.indexOf("PATIENT_ID")];
    const rule = e.range.getDataValidation();
    e.range.setDataValidation(null).setValue(pId);
    const ageIdx = headers.indexOf("AGE");
    if (ageIdx !== -1 && match[vHeaders.indexOf("DATE_OF_BIRTH")] instanceof Date) {
      e.range.getSheet().getRange(rowNum, startCol + ageIdx).setValue(calculateAge(match[vHeaders.indexOf("DATE_OF_BIRTH")]));
    }
    if (rule) e.range.setDataValidation(rule);
  }
}

function getFirstEmptyRowInRange(range) {
  const values = range.getValues();
  for (let i = 0; i < values.length; i++) {
    if (values[i].join("").trim() === "") return range.getRow() + i;
  }
  return range.getLastRow() + 1;
}

function calculateAge(dob) {
  const today = new Date();
  let age = today.getFullYear() - dob.getFullYear();
  if (today.getMonth() < dob.getMonth() || (today.getMonth() === dob.getMonth() && today.getDate() < dob.getDate())) age--;
  return age;
}

function isCellInNamedRange(cell, nr) {
  if (cell.getSheet().getName() !== nr.getSheet().getName()) return false;
  return (cell.getRow() >= nr.getRow() && cell.getRow() <= nr.getLastRow() && cell.getColumn() >= nr.getColumn() && cell.getColumn() <= nr.getLastColumn());
}
