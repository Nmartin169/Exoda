}

/**
* 3. PHYSICIAN_ENTRY_RANGE (Out/Update + SYNC TRIGGER)
*/
function updatePhysicianEntry() {
 const ss = SpreadsheetApp.getActiveSpreadsheet();
 const range = ss.getRangeByName("PHYSICIAN_ENTRY_RANGE");
 const vals = range.getValues()[0];
 const encounterId = vals[4];

 const masterSs = SpreadsheetApp.openById(MASTER_ID);
 const masterSheet = masterSs.getSheetByName("Encounter");
 const targetRow = findRowById(masterSheet, 6, encounterId);

 if (targetRow === -1) return;

 // 1. Save Physician data to Encounter Tab
 masterSheet.getRange(targetRow, 15, 1, 9).setValues([[vals[13], vals[14], vals[15], vals[16], vals[17], vals[18], vals[19], vals[20], vals[21]]]);

 // 2. --- NEW SYNC LOGIC ---
 // This pushes the combined Nurse/Physician data to the Pharmacy sheet
 syncToPharmacy(masterSs, encounterId);

 // 3. Clear range
 [1, 14, 15, 16, 17, 18, 19, 20, 21, 22].forEach(colIdx => range.getCell(1, colIdx).clearContent());
 SpreadsheetApp.getUi().alert("Physician Entry Recorded & Synced to Pharmacy.");
}

