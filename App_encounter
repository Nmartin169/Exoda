// --- CONFIGURATION ---
const MASTER_ID = "1Su8LqmUv3pQwpdKCJUJ8KW2cve7Dac9CxVoUR1d78HQ";

/**
* 1. NURSE_ENTRY_1_RANGE (In/Create)
*/
function submitNurseEntry1() {
 const ss = SpreadsheetApp.getActiveSpreadsheet();
 const range = ss.getRangeByName("NURSE_ENTRY_1_RANGE");
 const vals = range.getValues()[0]; 
 const masterSs = SpreadsheetApp.openById(MASTER_ID);
 const masterSheet = masterSs.getSheetByName("Encounter");

 const patientId = vals[1];
 const visitDate = new Date(vals[2]);
 const dateStr = Utilities.formatDate(visitDate, Session.getScriptTimeZone(), "yyyyMMdd");

 const idColumn = masterSheet.getRange("A:A").getValues().flat();
 const count = idColumn.filter(id => id == patientId).length + 1;
 const encounterId = `${dateStr}-${patientId}-${("0" + count).slice(-2)}`;

 const nextRow = masterSheet.getLastRow() + 1;

 masterSheet.getRange(nextRow, 1).setValue(vals[1]); 
 masterSheet.getRange(nextRow, 2).setValue(vals[2]); 
 masterSheet.getRange(nextRow, 3).setValue(new Date()); 
 masterSheet.getRange(nextRow, 4).setValue(vals[3]); 
 masterSheet.getRange(nextRow, 5).setValue(vals[4]); 
 masterSheet.getRange(nextRow, 6).setValue(vals[5]); 
 masterSheet.getRange(nextRow, 7).setValue(encounterId); 
 masterSheet.getRange(nextRow, 8, 1, 7).setValues([[vals[6], vals[7], vals[8], vals[9], vals[10], vals[11], vals[12]]]); 

 [1, 3, 7, 8, 9, 10, 11, 12, 13].forEach(colIdx => range.getCell(1, colIdx).clearContent());

 SpreadsheetApp.getUi().alert("New Encounter Created. ID: " + encounterId);
}
