  colsToMirror.forEach(colName => {
    const srcIdx = encounterHeaders.indexOf(colName);
    const destIdx = pharmacyHeaders.indexOf(colName);
    
    if (srcIdx !== -1 && destIdx !== -1) {
      let value = encounterSheet.getRange(rowNum, startCol + srcIdx).getValue();
      
      // CLEANUP LOGIC: 
      // If the value is a string and ends with a trailing comma/space, 
      // remove ONLY the last one for the Pharmacy record.
      if (typeof value === 'string' && value.endsWith(", ")) {
        value = value.substring(0, value.length - 2);
      }

      pharmacySheet.getRange(writeRow, pStartCol + destIdx).setValue(value);
    }
  });
