/**
 * Handles the DOSAGE column to allow repeating values (e.g., 1, 1, 1).
 */
function handleMultiDosageAppend(ctx) {
  const e = ctx.e;
  const newValue = e.value;
  const oldValue = e.oldValue;

  // If the cell was empty or user is clearing it, do nothing
  if (!oldValue || !newValue) return;

  // Append the new dosage to the existing string
  // This bypasses the "no-change" restriction of standard dropdowns
  const combinedValue = oldValue + ", " + newValue;
  ctx.range.setValue(combinedValue);
}
