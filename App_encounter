}

/**
 * HELPER: Sync Encounter data to Pharmacy sheet
 */
function syncToPharmacy(masterSs, encounterId) {
  const encSheet = masterSs.getSheetByName("Encounter");
  const pharmSheet = masterSs.getSheetByName("Pharmacy");
  
  const encRow = findRowById(encSheet, 6, encounterId);
  if (encRow === -1) return;
  
  // Get full row from Encounter (Cols 1-23)
  const rowData = encSheet.getRange(encRow, 1, 1, 23).getValues()[0];
  
  // Find or Create row in Pharmacy
  let pharmRow = findRowById(pharmSheet, 4, encounterId);
  if (pharmRow === -1) {
    pharmRow = pharmSheet.getLastRow() + 1;
  }

  // Map data to Pharmacy (Cols 1-10)
  // Mapping: PID, Date, Time, EncID, Med, Strength, Route, Dosage, Frequency, Physician
  const pharmacyMap = [
    [rowData[0], rowData[1], rowData[2], rowData[5], rowData[16], 
     rowData[17], rowData[18], rowData[19], rowData[20], rowData[22]]
  ];

  pharmSheet.getRange(pharmRow, 1, 1, 10).setValues(pharmacyMap);
}

/**
* HELPER: Find Row By ID
*/
function findRowById(sheet, colIndex, id) {
 const data = sheet.getRange(1, colIndex, sheet.getLastRow()).getValues().flat();
 for (let i = 0; i < data.length; i++) {
   if (data[i].toString() === id.toString() && id !== "") return i + 1;
 }
 return -1;
}
