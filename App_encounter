/**
 * Main Encounter Logic
 */
function handleEncounterLogic(ctx) {
  const rowNum = ctx.range.getRow();

  // 1. Patient Lookup
  if (ctx.columnName === "PATIENT_ID") {
    handlePatientIdSwap(ctx.e, ctx.headers, rowNum, ctx.startCol);
  }

  // 2. Category Selection -> Setup Dropdown for Drug Column
  if (ctx.columnName === "MEDICATION_CATEGORY") {
    handleMedicationDropdown(ctx);
  }

  // 3. Drug Selection -> Append to List (Multiple Entries)
  if (ctx.columnName === "DRUG_NAME") {
    handleMultiDrugAppend(ctx);
  }

  // 4. ID Generation & Pharmacy Sync
  pollAndGenerateEncounterId(ctx.sheet, ctx.activeRangeObject, rowNum, ctx.startCol, ctx.headers);

  const pharmacyTriggers = ["PATIENT_ID", "ENCOUNTER_ID", "MEDICATION_CATEGORY", "DRUG_NAME", "DOSAGE"];
  if (pharmacyTriggers.includes(ctx.columnName)) {
    syncToPharmacy(ctx.sheet, rowNum, ctx.startCol, ctx.headers);
  }
}

/**
 * Updates the DRUG_NAME dropdown based on the category.
 * Starts from Reference_Sheet Row 4, Columns G & H.
 */
function handleMedicationDropdown(ctx) {
  const ss = ctx.source;
  const refSheet = ss.getSheetByName("Reference_Sheet");
  if (!refSheet) return;

  const drugNameCell = ctx.range.offset(0, 1);
  const selectedCategory = ctx.range.getValue();

  if (selectedCategory === "") {
    drugNameCell.clearDataValidations();
    return;
  }

  const startRow = 4;
  const lastRow = refSheet.getLastRow();
  const refData = refSheet.getRange(startRow, 7, lastRow - startRow + 1, 2).getValues();
  
  // Filter drugs for the specific category chosen
  const filteredDrugs = refData
    .filter(row => row[0].toString().trim() === selectedCategory.toString().trim())
    .map(row => row[1])
    .filter(name => name !== "");

  if (filteredDrugs.length > 0) {
    const rule = SpreadsheetApp.newDataValidation()
      .requireValueInList(filteredDrugs)
      .setAllowInvalid(true) // Set to true so the "list" of drugs doesn't trigger an error
      .build();
    drugNameCell.setDataValidation(rule);
  }
}

/**
 * Appends the newly selected drug to the existing string in the cell.
 */
function handleMultiDrugAppend(ctx) {
  const oldValue = ctx.e.oldValue;
  const newValue = ctx.e.value;

  // If there was already a value and it's not a duplicate, append it
  if (oldValue && newValue && oldValue !== newValue) {
    const items = oldValue.split(",").map(i => i.trim());
    
    // Prevent adding the same drug twice in one cell
    if (!items.includes(newValue)) {
      const combinedValue = oldValue + ", " + newValue;
      ctx.range.setValue(combinedValue);
    }
  }
}
